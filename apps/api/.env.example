DATABASE_URL="postgresql://postgres:postgres@localhost:5432/esqueleton"
PORT=3001
CORS_ORIGIN="http://localhost:3000"
JWT_SECRET="troque-em-producao"

# Opcional: guarda os contadores do limite de requisições em um Redis compartilhado.
# Necessário em produção serverless (Vercel), onde cada instância teria contadores
# próprios na memória — ex: Upstash (tem plano gratuito). Sem definir, os contadores
# ficam na memória do processo, o que é suficiente em dev e VPS.
# REDIS_URL="rediss://default:senha@xxx.upstash.io:6379"
