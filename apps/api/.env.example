DATABASE_URL="postgresql://postgres:postgres@localhost:5432/esqueleton"
PORT=3001
CORS_ORIGIN="http://localhost:3000"
JWT_SECRET="troque-em-producao"

# Opcional: guarda os contadores do limite de requisições em um Redis compartilhado.
# Necessário em produção serverless (Vercel), onde cada instância teria contadores
# próprios na memória — ex: Upstash (tem plano gratuito). Sem definir, os contadores
# ficam na memória do processo, o que é suficiente em dev e VPS.
# REDIS_URL="rediss://default:senha@xxx.upstash.io:6379"

# E-mail transacional via Resend (reset de senha e verificação de e-mail).
# Sem a chave, os envios viram avisos no log — o sistema funciona normalmente em dev.
# RESEND_API_KEY="re_xxxxxxxxxxxx"
# FROM_EMAIL="noreply@seudominio.com.br"

# Endereço do site — usado para montar os links enviados por e-mail e o retorno do checkout
FRONTEND_URL="http://localhost:3000"

# Cobrança recorrente via MercadoPago (assinatura de planos).
# Sem o token, as operações de pagamento ficam desabilitadas (ok em dev).
# MERCADOPAGO_ACCESS_TOKEN="APP_USR-xxxx"
# MERCADOPAGO_WEBHOOK_SECRET="xxxxx"

# Armazenamento de imagens no Cloudflare R2 (S3-compatible).
# Sem as credenciais, imagens ficam como base64 no banco (ok em dev).
# Em produção, todas as 5 variáveis são OBRIGATÓRIAS — a API não inicia sem elas.
# R2_ACCOUNT_ID="seu-account-id"
# R2_ACCESS_KEY_ID="sua-access-key"
# R2_SECRET_ACCESS_KEY="sua-secret-key"
# R2_BUCKET_NAME="esqueleton-images"
# R2_PUBLIC_URL="https://img.seudominio.com.br"
