{
  "version": 2,
  "builds": [
    {
      "src": "src/vercel.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/vercel.ts"
    }
  ],
  "crons": [
    {
      "path": "/api/jobs/limpeza-lgpd",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/jobs/verificar-assinaturas",
      "schedule": "0 4 10 * *"
    }
  ]
}
