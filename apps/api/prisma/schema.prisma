generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Loja (tenant) — cada cliente do SaaS tem a sua.
// Todo dado do sistema pertence a uma loja através da coluna storeId.
model Store {
  id        String   @id @default(cuid())
  // Identificador usado na URL pública (ex: "perfumaria-ana") — letras minúsculas, números e hífen
  slug      String   @unique
  name      String
  // ACTIVE = funcionando | SUSPENDED = suspensa (preparação para a etapa de cobrança)
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  products      Product[]
  categories    Category[]
  featured      Featured[]
  promotions    Promotion[]
  coupons       Coupon[]
  profile       StoreProfile?
  orders        Order[]
  customers     Customer[]
  productEvents ProductEvent[]
  notifications Notification[]
  subscriptions Subscription[]
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  password      String
  // OWNER = criou a loja, controle total | STAFF = convidado, acesso limitado
  role          String   @default("STAFF")
  // true = e-mail verificado | false = pendente de verificação
  emailVerified Boolean  @default(false)
  storeId       String
  store         Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())

  passwordResetTokens         PasswordResetToken[]
  emailVerificationTokens     EmailVerificationToken[]

  @@index([storeId])
}

// Token de redefinição de senha — expira em 1 hora, uso único
model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([token])
  @@index([userId])
}

// Token de verificação de e-mail — enviado ao criar a conta, expira em 7 dias
model EmailVerificationToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([token])
  @@index([userId])
}

model Product {
  id            String            @id @default(cuid())
  brand         String?
  name          String
  description   String?
  price         Float
  originalPrice Float?
  imageUrl      String?
  storeId       String
  store         Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  categories    ProductCategory[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([storeId])
}

// Categoria do catálogo com suporte a hierarquia (pai → filhos) de qualquer profundidade
model Category {
  id        String            @id @default(cuid())
  name      String
  parentId  String?
  parent    Category?         @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[]        @relation("CategoryTree")
  storeId   String
  store     Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  products  ProductCategory[]
  createdAt DateTime          @default(now())

  @@index([storeId])
}

// Seção "Em destaque" exibida no topo do catálogo — apenas uma pode estar ativa por loja
model Featured {
  id         String   @id @default(cuid())
  title      String
  // Texto da tag no canto direito do cabeçalho (ex: "Destaque", "Oferta")
  tag        String
  // IDs dos produtos exibidos na seção
  productIds String[]
  startDate  String?
  endDate    String?
  startTime  String?
  endTime    String?
  active     Boolean  @default(false)
  storeId    String
  store      Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@index([storeId])
}

// Promoção aplicada automaticamente a produtos do catálogo
model Promotion {
  id             String   @id @default(cuid())
  name           String
  // Tipo é apenas um rótulo visual — todos os campos estão sempre disponíveis
  type           String
  discountPercent Float?
  discountValue  Float?
  buyQuantity    Int?
  getQuantity    Int?
  kitPrice       Float?
  // IDs dos produtos incluídos na promoção
  productIds     String[]
  startTime      String?
  endTime        String?
  startDate      String?
  endDate        String?
  description    String?
  // Cor hexadecimal da borda exibida no card do produto (ex: "#f97316")
  color          String?
  active         Boolean  @default(true)
  // Ordem de prioridade — promoção com menor valor tem preferência sobre as demais
  priority       Int      @default(0)
  storeId        String
  store          Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())

  @@index([storeId])
}

// Cupom de desconto que o cliente digita no checkout
model Coupon {
  id                String   @id @default(cuid())
  code              String
  description       String?
  // Tipo de desconto: percentage = percentual, fixed = valor fixo em reais
  discountType      String
  discountPercent   Float?
  discountValue     Float?
  minimumOrderValue Float?
  // null = sem limite de usos
  maxUses           Int?
  usedCount         Int      @default(0)
  maxUsesPerUser    Int?
  // IDs dos produtos elegíveis — vazio significa todos os produtos
  productIds        String[]
  startDate         String?
  endDate           String?
  active            Boolean  @default(true)
  storeId           String
  store             Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())

  // O código é único dentro de cada loja — lojas diferentes podem ter o mesmo código
  @@unique([storeId, code])
  @@index([storeId])
}

// Perfil da loja — um por loja, com identidade visual e dados de contato
model StoreProfile {
  id         String   @id @default(cuid())
  storeId    String   @unique
  store      Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  storeName  String   @default("Minha Loja")
  address    String?
  whatsapp   String?
  instagram  String?
  logoUrl    String?
  // Cor principal do tema em hex (ex: "#e11d48") — usada nos botões e acentos do catálogo
  themeColor    String   @default("#000000")
  // Mensagens exibidas na barra acima do cabeçalho em rotação
  announcements String[]
  updatedAt     DateTime @updatedAt
}

// Pedido gerado quando o cliente clica em "Enviar pelo WhatsApp" — confirmado depois pelo admin
model Order {
  id            String   @id @default(cuid())
  // Número de 6 dígitos exibido na mensagem do WhatsApp — usado para busca no dashboard
  orderNumber   String
  customerName  String?
  customerPhone String?
  // Itens do pedido serializados em JSON — Array de { productId, productName, quantity, unitPrice, lineTotal, promotionName? }
  items         Json
  subtotal      Float
  discount      Float    @default(0)
  total         Float
  couponCode    String?
  // PENDING = aguardando confirmação | SOLD = venda confirmada | NOT_SOLD = não vendido
  status        String   @default("PENDING")
  storeId       String
  store         Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // O número do pedido é único dentro de cada loja
  @@unique([storeId, orderNumber])
  @@index([storeId])
  @@index([status])
  @@index([createdAt])
}

// Cliente identificado — nome e telefone coletados na sacola antes de enviar pelo WhatsApp
model Customer {
  id        String   @id @default(cuid())
  name      String
  // Telefone usado como identificador — upsert ao cadastrar o mesmo número novamente
  phone     String
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // O telefone é único dentro de cada loja — a mesma pessoa pode ser cliente de várias lojas
  @@unique([storeId, phone])
  @@index([storeId])
}

// Registro de eventos de produto para analytics — sacola e envio pelo WhatsApp
model ProductEvent {
  id            String   @id @default(cuid())
  productId     String
  // Nome denormalizado para preservar histórico mesmo se o produto for excluído
  productName   String
  // 'CART_ADD' | 'WHATSAPP_SEND' | 'LINK_COPY' | 'PRODUCT_VIEW' | 'FAVORITE_ADD' | 'FEATURED_CLICK'
  eventType     String
  // Promoção ativa no momento do evento — null se o produto estava sem promoção
  promotionId   String?
  promotionName String?
  // Cupom aplicado — preenchido apenas em WHATSAPP_SEND
  couponCode    String?
  // Seção em destaque que originou o evento — preenchido em FEATURED_CLICK e CART_ADD vindos de destaque
  featuredId    String?
  featuredName  String?
  storeId       String
  store         Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())

  @@index([storeId])
  @@index([productId])
  @@index([eventType])
  @@index([createdAt])
}

// Notificação do painel administrativo — pedidos, expiração de promoções, cupons e destaques
model Notification {
  id        String   @id @default(cuid())
  // Tipo: NEW_ORDER | PROMOTION_ENDED | COUPON_ENDED | FEATURED_ENDED
  type      String
  // Texto principal exibido na notificação
  title     String
  // Detalhe adicional opcional (ex: nome do cliente, código do cupom)
  body      String?
  // ID do recurso relacionado — usado para evitar notificações duplicadas do mesmo evento
  entityId  String?
  // PENDING = não lida | READ = lida
  status    String   @default("PENDING")
  // Dados extras em JSON — ex: { customerPhone, customerName, total } para NEW_ORDER
  metadata  String?
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([storeId])
  @@index([status])
  @@index([createdAt])
  // Impede notificações duplicadas para o mesmo tipo + entidade dentro da mesma loja
  @@unique([storeId, type, entityId])
}

// Plano de assinatura da plataforma — define limites e preço
// Entidade global (não pertence a uma loja) — gerenciada pelo super-admin
model Plan {
  id                           String   @id @default(cuid())
  name                         String
  // Identificador curto na URL (ex: "gratuito", "profissional")
  slug                         String   @unique
  // Limites em JSON: { maxProducts, maxUsers, maxOrdersPerMonth }
  limits                       Json
  // Preço em centavos — 0 = gratuito
  priceInCents                 Int      @default(0)
  // Período de cobrança: MONTHLY ou YEARLY
  billingPeriod                String   @default("MONTHLY")
  // ID do plano de recorrência no MercadoPago (preenchido ao criar plano pago)
  mercadoPagoPreapprovalPlanId String?
  active                       Boolean  @default(true)
  // Ordem de exibição na página de preços (menor = primeiro)
  sortOrder                    Int      @default(0)
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt

  subscriptions Subscription[]
}

// Assinatura de uma loja a um plano — cada loja tem no máximo uma assinatura ativa
model Subscription {
  id                         String    @id @default(cuid())
  storeId                    String
  store                      Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  planId                     String
  plan                       Plan      @relation(fields: [planId], references: [id])
  // ACTIVE = em dia | PAUSED = pagamento pendente | CANCELLED = cancelada | PENDING = aguardando pagamento
  status                     String    @default("PENDING")
  // ID da assinatura recorrente no MercadoPago
  mercadoPagoPreapprovalId   String?
  currentPeriodStart         DateTime?
  currentPeriodEnd           DateTime?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  @@index([storeId])
  @@index([planId])
}

// Tabela de junção — permite que um produto pertença a várias categorias
model ProductCategory {
  productId  String
  categoryId String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
}
