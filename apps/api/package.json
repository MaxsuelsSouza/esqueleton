{
  "name": "@esqueleton/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "node scripts/com-perfil.mjs tsx watch src/main.ts",
    "build": "tsup src/main.ts --format cjs",
    "build:vercel": "prisma generate && tsup src/vercel.ts --format cjs --out-dir dist",
    "start": "node dist/main.js",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "prisma generate",
    "db:migrate": "node scripts/com-perfil.mjs prisma migrate dev",
    "db:studio": "node scripts/com-perfil.mjs prisma studio"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@esqueleton/shared": "workspace:*",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.1.0",
    "@fastify/rate-limit": "^10.3.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^2.4.3",
    "fastify": "^5.9.0",
    "fastify-plugin": "^5.0.1",
    "ioredis": "^5.4.1",
    "mercadopago": "^3.1.0",
    "resend": "^6.12.4",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.12.0",
    "prisma": "^6.19.3",
    "tsup": "^8.0.2",
    "tsx": "^4.7.3",
    "typescript": "^5.4.0",
    "vitest": "^3.2.6"
  }
}
